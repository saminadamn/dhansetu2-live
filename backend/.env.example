# Server
PORT=5000

# MongoDB connection string
MONGODB_URI=

# URL of the ml_model FastAPI service's /predict endpoint
# e.g. http://localhost:8000/predict (local) or https://your-ml-service.onrender.com/predict (prod)
ML_API_URL=

# Secret used to sign/verify JWTs issued on login
JWT_SECRET=

# Google Gemini API key (used for OCR + speech-to-text in /api/ai/*)
GEMINI_API_KEY=

# Comma-separated list of allowed frontend origins for CORS
# e.g. https://your-frontend.vercel.app,http://localhost:5173
FRONTEND_URL=http://localhost:5173

# Bhashini (bhashini.gov.in) translation API — optional. Get credentials at
# https://bhashini.gov.in. Until all three are set, /api/bhashini/translate
# returns 503 and the app keeps using its built-in i18next translations.
BHASHINI_USER_ID=
BHASHINI_UDYAT_API_KEY=
BHASHINI_INFERENCE_API_KEY=
# Optional — defaults to Bhashini's public translation pipeline ID if unset
BHASHINI_PIPELINE_ID=

# RabbitMQ connection string for the async scoring pipeline — optional.
# e.g. amqp://localhost (local Docker) or a CloudAMQP URL in production.
# If unset (or unreachable), POST /api/loans/apply falls back to scoring
# synchronously in-request instead of publishing to the worker pipeline.
RABBITMQ_URL=

# Cloudinary document storage — optional. From your Cloudinary dashboard,
# format: cloudinary://<api_key>:<api_secret>@<cloud_name>
# If unset, POST /api/uploads/document returns 503 and the loan form
# submits without hosted document attachments.
CLOUDINARY_URL=

# ClamAV daemon for document scanning. Production requires a clean scan by
# default; set VIRUS_SCAN_REQUIRED=false only for local development.
CLAMAV_HOST=
CLAMAV_PORT=3310
VIRUS_SCAN_REQUIRED=

# pino log level — optional, defaults to "info". Set to "debug" for
# verbose output.
LOG_LEVEL=

# Ports each worker's standalone /metrics server listens on — optional,
# default to 9101/9102/9103.
SCORING_METRICS_PORT=
DECISION_METRICS_PORT=
NOTIFICATION_METRICS_PORT=
